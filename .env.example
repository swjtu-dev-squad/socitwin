# =============================================================================
# OASIS Dashboard Environment Configuration
# =============================================================================
# Copy this file to .env and configure your environment variables
# The .env file is automatically loaded by the Python backend
# =============================================================================

# =============================================================================
# FRONTEND / NODE.JS VARIABLES (Vite)
# =============================================================================
# These variables are automatically loaded by Vite during development
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

NEXT_PUBLIC_API_BASE=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Gemini API key for additional AI features (optional)
GEMINI_API_KEY=

# =============================================================================
# PYTHON BACKEND - OASIS ENGINE CONFIGURATION
# =============================================================================
# These variables control the OASIS simulation engine behavior
# python-dotenv automatically loads these when the backend starts

# =============================================================================
# Model Runtime Configuration
# =============================================================================
# Platform: Model inference backend (ollama, vllm, openai, openrouter, deepseek)
#
# Choose your platform:
# - ollama: Local Ollama instance (default, free, requires GPU)
# - vllm: OpenAI-compatible vLLM service (local, requires GPU)
# - openai: OpenAI API (paid, fast)
# - openrouter: OpenRouter API (paid, very fast, multiple model options)
# - deepseek: DeepSeek API (paid, fast, cheapest, Chinese invoice available)
OASIS_MODEL_PLATFORM=ollama

# Model Type: Specific model name to use
# For Ollama: qwen3:8b, llama3:8b, mistral:7b, etc.
# For vLLM: Same as Ollama model names
# For OpenAI: gpt-4o-mini, gpt-3.5-turbo, etc.
# For OpenRouter: deepseek/deepseek-chat, google/gemini-flash-1.5, etc.
# For DeepSeek: deepseek-chat, deepseek-coder
OASIS_MODEL_TYPE=qwen3:8b

# Model URL: Base URL of the model service
# For local Ollama: http://127.0.0.1:11434/v1
# For vLLM: http://localhost:8000/v1
# For OpenAI: https://api.openai.com/v1 (default, can be omitted)
# For OpenRouter: https://openrouter.ai/api/v1 (default, can be omitted)
# For DeepSeek: https://api.deepseek.com (default, can be omitted)
OASIS_MODEL_URL=http://127.0.0.1:11434/v1

# Model URLs (optional): Comma-separated list for load balancing
# Leave empty to use OASIS_MODEL_URL
OASIS_MODEL_URLS=

# Model API Key (optional): Required for OpenAI, OpenRouter, and DeepSeek
# For DeepSeek: Get your key at https://platform.deepseek.com/api_keys
OASIS_MODEL_API_KEY=

# Context Window: Declared context window size of the model
# Check your model's specifications for the correct value
OASIS_MODEL_CONTEXT_WINDOW=8192

# Context Token Limit: Budget reserved for conversation context
# Recommended: Keep below full context window to leave room for system prompt
OASIS_CONTEXT_TOKEN_LIMIT=6144

# Generation Max Tokens: Maximum tokens for a single model response
# Lower values = faster responses, Higher values = longer responses
OASIS_MODEL_GENERATION_MAX_TOKENS=256

# Model Timeout: Request timeout in seconds
# Increased to 120s to handle potential queue wait times at high concurrency
# DeepSeek may queue requests during high traffic (keeps connection alive for up to 10min)
# For Ollama/local: 30-60s is sufficient
# For DeepSeek/OpenRouter: 120s recommended for high concurrency
OASIS_MODEL_TIMEOUT=120

# Model Max Retries: Number of retry attempts for failed requests
OASIS_MODEL_MAX_RETRIES=3

# Model Temperature: Controls randomness in model responses (0.0 - 1.0)
# - 0.0 - 0.3: Very conservative, deterministic (good for code, math)
# - 0.4 - 0.6: Moderate randomness (good for dialogue, Q&A)
# - 0.7 - 0.9: Creative, diverse (recommended for social simulation)
# - 1.0: Maximum randomness, unpredictable (good for creative writing)
# Leave empty to use platform defaults:
#   - Ollama: 0.4
#   - DeepSeek: 0.8 (recommended for OASIS)
#   - OpenAI: 0.7
#   - OpenRouter: 0.7
OASIS_MODEL_TEMPERATURE=

# =============================================================================
# Memory and Performance Configuration
# =============================================================================
# Memory Window Size: Number of recent interactions to keep in agent memory
# Leave empty for default behavior
OASIS_CONTEXT_WINDOW_SIZE=

# Step Concurrency: Number of agents to run concurrently in each step
# E2E simulation is I/O-bound (waiting for API responses), so high concurrency is beneficial
# DeepSeek API does NOT limit concurrent requests - can queue requests during high traffic
# Recommended settings:
#   - Small tests (<50 agents): Set to agent count for full concurrency
#   - Medium tests (50-100 agents): Set to 50
#   - Large tests (100+ agents): Set to 100
# Default: 50 (increased from 8 for better performance)
OASIS_STEP_CONCURRENCY=50

# Polarization Chunk Size: Batch size for polarization stance analysis
# Also I/O-bound, can be increased for faster processing
# Recommended: 10-30 for DeepSeek API
# Default: 20 (increased from 8)
OASIS_POLARIZATION_CHUNK_SIZE=20

# =============================================================================
# HTTP Client Connection Pool Configuration (Advanced)
# =============================================================================
# HTTP connection pool limits for API calls
# Increase these values to support higher concurrency (200+ agents)
# Only applies when using OpenAI-compatible APIs (OpenAI, DeepSeek, OpenRouter)

# Max concurrent HTTP connections
# Recommended: 200 for medium-scale simulations (100-500 agents)
# Usage: OASIS_HTTP_MAX_CONNECTIONS=200
OASIS_HTTP_MAX_CONNECTIONS=

# Max keep-alive connections (connection reuse)
# Recommended: 100 for medium-scale simulations
# Usage: OASIS_HTTP_MAX_KEEPALIVE_CONNECTIONS=100
OASIS_HTTP_MAX_KEEPALIVE_CONNECTIONS=

# =============================================================================
# Python Environment Configuration
# =============================================================================
# These variables optimize Python library behavior

# Tokenizers Parallelism: Set to 'false' to avoid warnings
TOKENIZERS_PARALLELISM=false

# PyTorch CUDA Memory Configuration: Reduces memory fragmentation
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# =============================================================================
# MongoDB Configuration (Dataset Storage)
# =============================================================================
# Connection string format: mongodb://username:password@host:port
MONGODB_URI=mongodb://username:password@host:port/oasis_dataset?authSource=admin
MONGODB_DATABASE=oasis_dataset

