# 统一行尾符为 LF (Linux/Unix 风格)
* text=auto eol=lf

# Python
*.py text eol=lf
*.txt text eol=lf

# 配置文件
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.env* text eol=lf

# 文档
*.md text eol=lf
*.rst text eol=lf

# 前端
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Shell 脚本
*.sh text eol=lf

# Git LFS - 大文件存储
*.safetensors filter=lfs diff=lfs merge=lfs -text
backend/LLaMA-Factory-main/data/miao2.json filter=lfs diff=lfs merge=lfs -text
