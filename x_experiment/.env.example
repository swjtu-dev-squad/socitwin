# DeepSeek配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ============================================================================
# X / Twitter API 凭证
# ============================================================================
# OAuth 1.0a — 用于发布推文（发帖）
X_API_KEY=your_x_api_key_here
X_API_KEY_SECRET=your_x_api_key_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# OAuth 2.0 Client — 用于读取（搜索热点等）
X_OAUTH2_CLIENT_ID=your_oauth2_client_id_here
X_OAUTH2_CLIENT_SECRET=your_oauth2_client_secret_here
X_OAUTH2_REFRESH_TOKEN=your_oauth2_refresh_token_here

# OAuth 2.0 Bearer Token（读取用）
TWITTER_BEARER_TOKEN=your_bearer_token_here

# 数据库路径（默认）
OASIS_DB_PATH=/home/liz/socitwin/backend/data/datasets/oasis_datasets.db

# 可选：日志级别
LOG_LEVEL=INFO

# 代理配置（可选）
# HTTPS_PROXY=http://your-proxy:port
# HTTP_PROXY=http://your-proxy:port
