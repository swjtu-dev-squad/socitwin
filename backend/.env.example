# Socitwin Backend Environment Variables

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Socitwin Backend

# CORS Origins (JSON array format)
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:3000"]

# Database
DATABASE_URL=sqlite:///./socitwin.db

# Simulation Settings
SIMULATION_MAX_AGENTS=1000
SIMULATION_DEFAULT_STEPS=100

# ============================================================================
# DeepSeek Configuration (Required for OASIS)
# ============================================================================
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============================================================================
# OpenAI Configuration (Optional - for alternative LLM support)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# Optional: Set custom base URL for proxy services
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Hugging Face Download Mirror / Cache
# ============================================================================
# OASIS Twitter recommendation models are downloaded through Hugging Face
# libraries. HF_ENDPOINT redirects those downloads to the configured mirror.
HF_ENDPOINT=https://hf-mirror.com

# Cache Hugging Face models under backend/data instead of the user home.
HF_HOME=./data/huggingface
SENTENCE_TRANSFORMERS_HOME=./data/huggingface/sentence-transformers

# ============================================================================
# OASIS Simulation Configuration
# ============================================================================
# Default social media platform: twitter or reddit
OASIS_DEFAULT_PLATFORM=twitter

# Default model to use for agents
OASIS_DEFAULT_MODEL=gpt-4o-mini

# Memory mode: upstream or action_v1
OASIS_MEMORY_MODE=upstream

# Maximum number of agents allowed
OASIS_MAX_AGENTS=1000

# Default number of simulation steps
OASIS_DEFAULT_STEPS=100

# Database path for simulation data
OASIS_DB_PATH=./data/simulations

# Explicit context budget for action_v1 prompt assembly
OASIS_CONTEXT_TOKEN_LIMIT=16384

# Timeout for simulation operations (seconds)
OASIS_TIMEOUT=300

# Number of retries for failed operations
OASIS_RETRY_COUNT=3

# ============================================================================
# Action_V1 Long-Term Memory
# ============================================================================
# Enable or disable the long-term sidecar when memory_mode=action_v1
OASIS_LONGTERM_ENABLED=true

# Persistent Chroma path used by the action_v1 long-term store
OASIS_LONGTERM_CHROMA_PATH=./data/memory/chroma

# Collection prefix; the runtime appends the simulation db stem
OASIS_LONGTERM_COLLECTION_PREFIX=action_v1

# Embedding backend: heuristic or openai_compatible
OASIS_LONGTERM_EMBEDDING_BACKEND=heuristic

# Optional embedding model / endpoint settings for openai_compatible backends
# OASIS_LONGTERM_EMBEDDING_MODEL=nomic-embed-text:latest
# OASIS_LONGTERM_EMBEDDING_API_KEY=
# OASIS_LONGTERM_EMBEDDING_BASE_URL=

# Whether to delete the Chroma collection when the runtime closes
OASIS_LONGTERM_DELETE_COLLECTION_ON_CLOSE=false

# ============================================================================
# Action_V1 Working Memory / Observation Preset Compatibility
# ============================================================================
# These keep the old oasis-dashboard env naming so migration does not need a
# parallel config vocabulary immediately.

# Observation shaping
# OASIS_V1_OBS_GROUPS_COUNT_GUARD=64
# OASIS_V1_OBS_COMMENTS_TOTAL_GUARD=512
# OASIS_V1_OBS_MESSAGES_TOTAL_GUARD=512
# OASIS_V1_OBS_POST_TEXT_CAP_CHARS=1200
# OASIS_V1_OBS_COMMENT_TEXT_CAP_CHARS=900
# OASIS_V1_OBS_MESSAGE_TEXT_CAP_CHARS=240

# Short-term budget
# OASIS_V1_RECENT_BUDGET_RATIO=0.35
# OASIS_V1_COMPRESSED_BUDGET_RATIO=0.10
# OASIS_V1_RECALL_BUDGET_RATIO=0.10
# OASIS_V1_RECENT_STEP_CAP=3
# OASIS_V1_COMPRESSED_BLOCK_CAP=12
# OASIS_V1_COMPRESSED_MERGE_TRIGGER_RATIO=0.90
# OASIS_V1_GENERATION_RESERVE_TOKENS=1024

# Recall preset
# OASIS_V1_RECALL_LIMIT=3
# OASIS_V1_RECALL_COOLDOWN_STEPS=2
# OASIS_V1_RECALL_MIN_TRIGGER_ENTITY_COUNT=0
# OASIS_V1_RECALL_ALLOW_TOPIC_TRIGGER=true
# OASIS_V1_RECALL_ALLOW_ANCHOR_TRIGGER=true
# OASIS_V1_RECALL_ALLOW_RECENT_ACTION_TRIGGER=true
# OASIS_V1_RECALL_ALLOW_SELF_AUTHORED_TRIGGER=true
# OASIS_V1_RECALL_DENY_REPEATED_QUERY_WITHIN_STEPS=2
# OASIS_V1_RECALL_MAX_REASON_TRACE_CHARS=120

# Summary preset
# OASIS_V1_SUMMARY_MAX_ACTION_ITEMS_PER_BLOCK=4
# OASIS_V1_SUMMARY_MAX_MERGE_SPAN=3
# OASIS_V1_SUMMARY_COMPRESSED_ACTION_BLOCK_DROP_PROTECTED_COUNT=2
# OASIS_V1_SUMMARY_MAX_ACTION_ITEMS_PER_RECENT_TURN=6
# OASIS_V1_SUMMARY_MAX_AUTHORED_EXCERPT_CHARS=120
# OASIS_V1_SUMMARY_MAX_TARGET_SUMMARY_CHARS=120
# OASIS_V1_SUMMARY_MAX_LOCAL_CONTEXT_CHARS=120
# OASIS_V1_SUMMARY_MAX_HEARTBEAT_ENTITY_SAMPLES=3
# OASIS_V1_SUMMARY_MAX_ANCHOR_ITEMS_PER_BLOCK=2
# OASIS_V1_SUMMARY_MAX_ENTITIES_PER_HEARTBEAT=3
# OASIS_V1_SUMMARY_MAX_STATE_CHANGES_PER_TURN=4
# OASIS_V1_SUMMARY_MAX_OUTCOME_DIGEST_CHARS=160
# OASIS_V1_SUMMARY_COMPRESSED_NOTE_TITLE=Compressed short-term memory:
# OASIS_V1_SUMMARY_RECALL_NOTE_TITLE=Relevant long-term memory:
# OASIS_V1_SUMMARY_OMIT_EMPTY_TEMPLATE_FIELDS=true

# Provider runtime preset
# OASIS_V1_PROVIDER_ERROR_MATCHERS_FILE=
# OASIS_V1_PROVIDER_NATIVE_OVERFLOW_TIERS=256:0.03,512:0.06
# OASIS_V1_PROVIDER_HEURISTIC_OVERFLOW_TIERS=512:0.06,1024:0.12
# OASIS_V1_PROVIDER_COUNTER_UNCERTAINTY_RESERVE_POLICY=heuristic_10pct_min256
# OASIS_V1_PROVIDER_MAX_BUDGET_RETRIES=4

# Development/Production
ENVIRONMENT=development
DEBUG=true
